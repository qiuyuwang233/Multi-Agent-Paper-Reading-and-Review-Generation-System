# DeepSeek API config
DEEPSEEK_API_KEY=YOUR_DEEPSEEK_API_KEY
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_MODEL=deepseek-chat
LLM_TEMPERATURE=0.2
LLM_TIMEOUT=120
LLM_MAX_RETRIES=2

# Embedding config
EMBEDDING_API_KEY=YOUR_EMBEDDING_API_KEY
EMBEDDING_BASE_URL=https://api.deepseek.com/v1
EMBEDDING_MODEL=embedding-2
EMBEDDING_TIMEOUT=120
EMBEDDING_FALLBACK_MODEL=BAAI/bge-small-zh-v1.5
ENABLE_LOCAL_EMBEDDING_FALLBACK=true

# Chroma vector store
CHROMA_COLLECTION_PREFIX=paper_chunks

# Retrieval and chunk settings
CHUNK_SIZE=800
CHUNK_OVERLAP=120
TOP_K=5

# Critic retry limit
MAX_RETRIES=2

# Logging
LOG_LEVEL=INFO

# Paths
DATA_DIR=data
OUTPUT_DIR=outputs

# arXiv download
ARXIV_PDF_BASE_URL=https://arxiv.org/pdf
DOWNLOAD_TIMEOUT=120

# FastAPI server
API_HOST=127.0.0.1
API_PORT=8000
