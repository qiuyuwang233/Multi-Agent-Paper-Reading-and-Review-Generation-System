# Python 缓存与虚拟环境
__pycache__/
*.py[cod]
.pytest_cache/
.mypy_cache/
.ruff_cache/
.venv/
venv/
env/

# 本地密钥与环境变量，禁止提交
.env
.env.*
!.env.example

# 本地运行数据与生成结果
data/papers/*
!data/papers/.gitkeep
data/vector_db/*
!data/vector_db/.gitkeep
outputs/*
!outputs/.gitkeep
!outputs/notes/.gitkeep
!outputs/related_work/.gitkeep
!outputs/reviews/.gitkeep
!outputs/comparison_tables/.gitkeep

# 日志与临时文件
*.log
*.tmp
*.bak

# IDE / 系统文件
.vscode/
.DS_Store
Thumbs.db
